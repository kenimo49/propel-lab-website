---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { company } from '../data/company';
import { profile } from '../data/profile';
---

<Layout title="会社概要 — 合同会社 Propel-Lab" description="合同会社Propel-Labの会社概要。福岡市天神を拠点に、AI・LLM技術を活用した事業を展開。">
  <Header />
  <main class="pt-24 pb-20">
    <div class="mx-auto max-w-4xl px-4">
      <h1 class="text-4xl font-bold mb-12">会社概要</h1>

      <section class="mb-12">
        <h2 class="text-2xl font-bold mb-6 pb-2 border-b border-gray-200">基本情報</h2>
        <table class="w-full text-left">
          <tbody>
            <tr class="border-b border-gray-100">
              <th class="py-3 pr-4 text-sm font-medium text-gray-500 w-32">会社名</th>
              <td class="py-3 text-gray-800">{company.name}（{company.nameKana}）</td>
            </tr>
            <tr class="border-b border-gray-100">
              <th class="py-3 pr-4 text-sm font-medium text-gray-500">所在地</th>
              <td class="py-3 text-gray-800">{company.address}</td>
            </tr>
            <tr class="border-b border-gray-100">
              <th class="py-3 pr-4 text-sm font-medium text-gray-500">代表者</th>
              <td class="py-3 text-gray-800">{company.representative}（{company.representativeKana}）</td>
            </tr>
            <tr class="border-b border-gray-100">
              <th class="py-3 pr-4 text-sm font-medium text-gray-500">設立</th>
              <td class="py-3 text-gray-800">{company.founded}</td>
            </tr>
            <tr class="border-b border-gray-100">
              <th class="py-3 pr-4 text-sm font-medium text-gray-500">資本金</th>
              <td class="py-3 text-gray-800">{company.capital}</td>
            </tr>
            <tr class="border-b border-gray-100">
              <th class="py-3 pr-4 text-sm font-medium text-gray-500">メール</th>
              <td class="py-3 text-gray-800">
                <a href={`mailto:${company.email}`} class="text-accent hover:underline">{company.email}</a>
              </td>
            </tr>
            <tr>
              <th class="py-3 pr-4 text-sm font-medium text-gray-500">URL</th>
              <td class="py-3 text-gray-800">
                <a href={company.url} class="text-accent hover:underline">{company.url}</a>
              </td>
            </tr>
          </tbody>
        </table>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl font-bold mb-4 pb-2 border-b border-gray-200">ミッション</h2>
        <p class="text-lg text-gray-700 leading-relaxed">「{company.mission}」</p>
      </section>

      <section>
        <h2 class="text-2xl font-bold mb-6 pb-2 border-b border-gray-200">代表者プロフィール</h2>
        <div class="bg-gray-50 rounded-xl p-8">
          <h3 class="text-xl font-bold">{profile.name}</h3>
          <p class="text-gray-500 mb-4">{profile.nameEn} / {profile.title} / {profile.experience}</p>
          <ul class="space-y-2 mb-4">
            {profile.highlights.map((h) => (
              <li class="text-gray-600 text-sm flex items-start gap-2">
                <span class="text-accent mt-0.5">&#9654;</span>
                <span>{h}</span>
              </li>
            ))}
          </ul>
          <div class="flex flex-wrap gap-3">
            {Object.entries(profile.links).map(([name, url]) => (
              <a
                href={url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm text-navy hover:text-accent transition-colors underline"
              >
                {name.charAt(0).toUpperCase() + name.slice(1)}
              </a>
            ))}
          </div>
        </div>
      </section>
    </div>
  </main>
  <Footer />
</Layout>
