---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<Layout title="Yureru — 心が揺れる音楽プロジェクト | Propel-Lab" description="Yureruは「心が揺れる」感情の瞬間を音楽・言葉・映像でやさしくすくい上げるプロジェクトです。バーチャルシンガーYumei、Silk Reignが参加。">
  <Header />
  <main class="pt-20">
    <!-- Hero -->
    <section class="relative py-32 bg-gradient-to-b from-sky-100 to-pink-50 text-navy overflow-hidden">
      <div class="relative z-10 mx-auto max-w-4xl px-4 text-center">
        <img src={`${base}images/yureru-logo.jpg`} alt="Yureru" class="w-48 h-48 mx-auto mb-8 rounded-2xl shadow-lg" />
        <h1 class="text-4xl md:text-6xl font-bold mb-6">Yureru</h1>
        <p class="text-lg md:text-xl text-gray-600 leading-relaxed max-w-2xl mx-auto">
          「心が揺れる」――そんな、言葉にならない感情の瞬間を<br/>
          音楽・言葉・映像でやさしくすくい上げるプロジェクトです。
        </p>
      </div>
    </section>

    <!-- About -->
    <section class="py-20 bg-white">
      <div class="mx-auto max-w-4xl px-4">
        <h2 class="text-3xl font-bold mb-8">プロジェクトについて</h2>
        <div class="space-y-4 text-gray-700 leading-relaxed">
          <p>繊細な"揺れ"に焦点を当て、意味を限定しない"余白"のある表現を通じて、聴く人それぞれの心にそっと寄り添う作品を目指しています。</p>
          <p>Yureruでは、多様なアーティストが参加。声や表現、世界観の異なる歌手たちが、まるで100通りの感情の鏡のように、それぞれの楽曲に命を吹き込んでいます。</p>
        </div>

        <div class="mt-8 grid grid-cols-2 md:grid-cols-4 gap-4 text-center">
          <div class="bg-gray-50 rounded-lg p-4">
            <div class="text-2xl font-bold text-accent">409+</div>
            <div class="text-sm text-gray-500">公開楽曲</div>
          </div>
          <div class="bg-gray-50 rounded-lg p-4">
            <div class="text-2xl font-bold text-accent">3,815</div>
            <div class="text-sm text-gray-500">YouTube登録者</div>
          </div>
          <div class="bg-gray-50 rounded-lg p-4">
            <div class="text-2xl font-bold text-accent">2</div>
            <div class="text-sm text-gray-500">所属アーティスト</div>
          </div>
          <div class="bg-gray-50 rounded-lg p-4">
            <div class="text-2xl font-bold text-accent">Spotify</div>
            <div class="text-sm text-gray-500">配信中</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Artists -->
    <section class="py-20 bg-gray-50">
      <div class="mx-auto max-w-4xl px-4">
        <h2 class="text-3xl font-bold mb-12">所属アーティスト</h2>

        <div class="space-y-12">
          <!-- Yumei -->
          <div class="bg-white rounded-xl overflow-hidden shadow-sm">
            <div class="h-64 overflow-hidden">
              <img src={`${base}images/yumei-banner.jpg`} alt="Yumei" class="w-full h-full object-cover" />
            </div>
            <div class="p-8">
              <div class="flex items-center gap-4 mb-4">
                <img src={`${base}images/yumei-portrait.jpg`} alt="Yumei" class="w-16 h-16 rounded-full object-cover shadow" />
                <div>
                  <h3 class="text-2xl font-bold">Yumei（ユメイ）</h3>
                  <p class="text-accent text-sm font-medium">メインボーカル</p>
                </div>
              </div>
              <div class="text-gray-700 leading-relaxed space-y-3">
                <p>誰かの記憶の奥で、そっと揺れている感情。そんな"名前のつかない気持ち"を、歌にしたく名づけました。</p>
                <p>静かな夜、ふと思い出した風景。届かなかった言葉。わたしの歌が、あなたの"ひとりの時間"に、そっと寄り添えますように。</p>
                <p class="text-sm text-gray-500 italic">─── もし、あなたの心がふるえたら、それは、きっと、わたしの声が届いた証です。</p>
              </div>
            </div>
          </div>

          <!-- Silk Reign -->
          <div class="bg-white rounded-xl p-8 shadow-sm opacity-70">
            <h3 class="text-2xl font-bold mb-2">Silk Reign（シルクレイン）</h3>
            <p class="text-accent text-sm font-medium mb-4">洋楽バラード — <span class="text-gray-400">coming soon</span></p>
          </div>
        </div>
      </div>
    </section>

    <!-- Popular Songs -->
    <section class="py-20 bg-white">
      <div class="mx-auto max-w-4xl px-4">
        <h2 class="text-3xl font-bold mb-8">人気曲</h2>
        <div class="grid md:grid-cols-2 gap-6">
          <div class="rounded-xl overflow-hidden shadow-sm">
            <div class="aspect-video">
              <iframe
                width="100%"
                height="100%"
                src="https://www.youtube.com/embed/b86a5Ah8MMo"
                title="【失恋ソング】君がいた場所で – Yumei"
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
                loading="lazy"
              ></iframe>
            </div>
            <div class="p-4 bg-gray-50">
              <h3 class="font-bold">【失恋ソング】君がいた場所で – Yumei</h3>
              <p class="text-sm text-gray-500">12,000+ 回再生</p>
            </div>
          </div>
          <div class="rounded-xl overflow-hidden shadow-sm">
            <div class="aspect-video">
              <iframe
                width="100%"
                height="100%"
                src="https://www.youtube.com/embed/TFOfX2S8nSk"
                title="【泣ける曲】あなたを想い出す夜に – Yumei"
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
                loading="lazy"
              ></iframe>
            </div>
            <div class="p-4 bg-gray-50">
              <h3 class="font-bold">【泣ける曲】あなたを想い出す夜に – Yumei</h3>
              <p class="text-sm text-gray-500">切ない想い出の歌・感動するバラード</p>
            </div>
          </div>
          <div class="rounded-xl overflow-hidden shadow-sm">
            <div class="aspect-video">
              <iframe
                width="100%"
                height="100%"
                src="https://www.youtube.com/embed/D3YJwirK0nw"
                title="【失恋ソング】ごめん、なんて今さら – Yumei"
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
                loading="lazy"
              ></iframe>
            </div>
            <div class="p-4 bg-gray-50">
              <h3 class="font-bold">【失恋ソング】ごめん、なんて今さら – Yumei</h3>
              <p class="text-sm text-gray-500">泣ける別れの歌・切ないバラード</p>
            </div>
          </div>
          <div class="rounded-xl overflow-hidden shadow-sm">
            <div class="aspect-video">
              <iframe
                width="100%"
                height="100%"
                src="https://www.youtube.com/embed/mP3koA75GUU"
                title="Yumei – 人気曲"
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
                loading="lazy"
              ></iframe>
            </div>
            <div class="p-4 bg-gray-50">
              <h3 class="font-bold">Yumei – 人気曲</h3>
              <p class="text-sm text-gray-500">心に響くバラード</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- World View -->
    <section class="py-20 bg-white">
      <div class="mx-auto max-w-4xl px-4">
        <h2 class="text-3xl font-bold mb-8">世界観</h2>
        <div class="flex flex-wrap gap-3">
          {['泣ける', 'エモい', '儚い', '夜', '雨', '手紙', '孤独', '記憶', 'INFJ', 'INFP', '繊細さん', 'HSP'].map(tag => (
            <span class="px-4 py-2 bg-navy/5 text-navy rounded-full text-sm">{tag}</span>
          ))}
        </div>
      </div>
    </section>

    <!-- Links -->
    <section class="py-20 bg-gray-50">
      <div class="mx-auto max-w-4xl px-4">
        <h2 class="text-3xl font-bold mb-8">OFFICIAL SNS</h2>
        <div class="grid sm:grid-cols-2 md:grid-cols-4 gap-4">
          <a href="https://youtube.com/@Yureru-s4n" target="_blank" rel="noopener noreferrer"
             class="block bg-white rounded-lg p-6 text-center hover:shadow-md transition-shadow">
            <div class="text-2xl mb-2">▶️</div>
            <div class="font-semibold">YouTube</div>
          </a>
          <a href="https://www.youtube.com/channel/UCxIwbaBIBxogNUbPLZqWR9g" target="_blank" rel="noopener noreferrer"
             class="block bg-white rounded-lg p-6 text-center hover:shadow-md transition-shadow">
            <div class="text-2xl mb-2">🎶</div>
            <div class="font-semibold">YouTube Music</div>
          </a>
          <a href="https://note.com/yureru_propel" target="_blank" rel="noopener noreferrer"
             class="block bg-white rounded-lg p-6 text-center hover:shadow-md transition-shadow">
            <div class="text-2xl mb-2">📝</div>
            <div class="font-semibold">note</div>
          </a>
          <a href="https://www.instagram.com/yureru_s4n/" target="_blank" rel="noopener noreferrer"
             class="block bg-white rounded-lg p-6 text-center hover:shadow-md transition-shadow">
            <div class="text-2xl mb-2">📷</div>
            <div class="font-semibold">Instagram</div>
          </a>
          <a href="https://open.spotify.com/intl-ja/artist/3bXlVrHqRcEn82MaGqfikD" target="_blank" rel="noopener noreferrer"
             class="block bg-white rounded-lg p-6 text-center hover:shadow-md transition-shadow">
            <div class="text-2xl mb-2">🎵</div>
            <div class="font-semibold">Spotify</div>
          </a>
        </div>
      </div>
    </section>


  </main>
  <Footer />
</Layout>
