---
import { company } from '../data/company';
import { profile } from '../data/profile';

const socialLinks = [
  { label: 'LinkedIn', href: profile.links.linkedin },
  { label: 'Qiita', href: profile.links.qiita },
  { label: 'Zenn', href: profile.links.zenn },
  { label: 'note', href: profile.links.note },
  { label: 'X', href: profile.links.x },
  { label: 'YouTube', href: profile.links.youtube },
  { label: 'Kindle', href: profile.links.kindle },
];
---

<footer class="bg-navy-dark text-gray-400 py-12">
  <div class="mx-auto max-w-6xl px-4">
    <div class="grid md:grid-cols-3 gap-8 mb-8">
      <div>
        <h3 class="text-white font-bold text-lg mb-3">Propel-Lab</h3>
        <p class="text-sm leading-relaxed">{company.mission}</p>
      </div>
      <div>
        <h4 class="text-white font-semibold mb-3">会社情報</h4>
        <ul class="text-sm space-y-1">
          <li>{company.name}</li>
          <li>{company.address}</li>
          <li>
            <a href={`mailto:${company.email}`} class="hover:text-white transition-colors">
              {company.email}
            </a>
          </li>
        </ul>
      </div>
      <div>
        <h4 class="text-white font-semibold mb-3">SNS</h4>
        <ul class="text-sm space-y-1">
          {socialLinks.map((link) => (
            <li>
              <a
                href={link.href}
                target="_blank"
                rel="noopener noreferrer"
                class="hover:text-white transition-colors"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
    <div class="border-t border-white/10 pt-6 text-center text-xs">
      <p>&copy; {new Date().getFullYear()} {company.name} All rights reserved.</p>
    </div>
  </div>
</footer>
