---
import { services } from '../data/services';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;

const serviceImages: Record<string, string> = {
  'LearningMate': 'learningmate-education.jpg',
  'AI-Loop': 'ai-loop-concept.jpg',
  'AutoCrew': 'autocrew-agent-system.jpg',
  'Yureru': 'yumei-butterfly.jpg',
};
---

<section id="services" class="py-20 bg-gray-50">
  <div class="mx-auto max-w-6xl px-4">
    <h2 class="text-3xl font-bold text-center mb-4">事業紹介</h2>
    <p class="text-center text-gray-500 mb-12">AI・LLM技術を軸にした4つの事業を展開</p>
    <div class="grid md:grid-cols-2 gap-8">
      {services.map((service) => (
        <div class="bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow border border-gray-100">
          <div class="h-48 overflow-hidden">
            <img
              src={`${base}images/${serviceImages[service.name] || ''}`}
              alt={service.name}
              class="w-full h-full object-cover"
            />
          </div>
          <div class="p-8">
            <h3 class="text-xl font-bold mb-1">
              {service.id === 'yureru' ? (
                <a href={`${base}yureru`} class="hover:text-accent transition-colors">{service.name} →</a>
              ) : service.name}
            </h3>
            <p class="text-sm text-accent font-medium mb-3">{service.category}</p>
            <p class="text-gray-600 mb-4">{service.summary}</p>
            <p class="text-sm text-gray-500">
              <span class="font-medium">対象:</span> {service.target}
            </p>
            <div class="mt-4 flex flex-wrap gap-2">
              {service.tech.map((t) => (
                <span class="text-xs px-2 py-1 bg-navy/5 text-navy rounded-full">{t}</span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
