---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { company } from '../data/company';
import { profile } from '../data/profile';
---

<Layout title="会社概要 — 合同会社 Propel-Lab" description="合同会社Propel-Labの会社概要。福岡市天神を拠点に、AI・LLM技術を活用した事業を展開。">
  <Header />
  <main class="pt-24 pb-20">
    <div class="mx-auto max-w-4xl px-4">
      <h1 class="text-4xl font-bold mb-12">会社概要</h1>

      <section class="mb-12">
        <h2 class="text-2xl font-bold mb-6 pb-2 border-b border-gray-200">基本情報</h2>
        <table class="w-full text-left">
          <tbody>
            <tr class="border-b border-gray-100">
              <th class="py-3 pr-4 text-sm font-medium text-gray-500 w-32">会社名</th>
              <td class="py-3 text-gray-800">{company.name}（{company.nameKana}）</td>
            </tr>
            <tr class="border-b border-gray-100">
              <th class="py-3 pr-4 text-sm font-medium text-gray-500">所在地</th>
              <td class="py-3 text-gray-800">{company.address}</td>
            </tr>
            <tr class="border-b border-gray-100">
              <th class="py-3 pr-4 text-sm font-medium text-gray-500">代表者</th>
              <td class="py-3 text-gray-800">{company.representative}（{company.representativeKana}）</td>
            </tr>
            <tr class="border-b border-gray-100">
              <th class="py-3 pr-4 text-sm font-medium text-gray-500">設立</th>
              <td class="py-3 text-gray-800">{company.founded}</td>
            </tr>
            <tr class="border-b border-gray-100">
              <th class="py-3 pr-4 text-sm font-medium text-gray-500">資本金</th>
              <td class="py-3 text-gray-800">{company.capital}</td>
            </tr>
            <tr class="border-b border-gray-100">
              <th class="py-3 pr-4 text-sm font-medium text-gray-500">メール</th>
              <td class="py-3 text-gray-800">
                <a href={`mailto:${company.email}`} class="text-accent hover:underline">{company.email}</a>
              </td>
            </tr>
            <tr>
              <th class="py-3 pr-4 text-sm font-medium text-gray-500">URL</th>
              <td class="py-3 text-gray-800">
                <a href={company.url} class="text-accent hover:underline">{company.url}</a>
              </td>
            </tr>
          </tbody>
        </table>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl font-bold mb-4 pb-2 border-b border-gray-200">ミッション</h2>
        <p class="text-lg text-gray-700 leading-relaxed">「{company.mission}」</p>
      </section>

      <section>
        <h2 class="text-2xl font-bold mb-6 pb-2 border-b border-gray-200">代表者プロフィール</h2>
        <div class="bg-[#0f172a] rounded-2xl p-8 text-center">
          <img
            src={`${base}images/avatar.jpg`}
            alt={profile.name}
            class="w-32 h-32 rounded-full object-cover mx-auto mb-4"
            style="border: 3px solid #1e3a5f;"
          />
          <h3 class="text-xl font-bold text-white mb-1">{profile.name}</h3>
          <p class="text-gray-400 mb-1">{profile.nameEn} / {profile.title}</p>
          <p class="text-sm text-gray-500 tracking-wider mb-6">LLMO · WebRTC · Real-time AI · Context Engineering</p>

          <p class="text-gray-300 text-sm leading-relaxed max-w-xl mx-auto mb-6">
            ソフトウェアエンジニア歴8年。Android/Web開発、ロボティクスを経て、現在はAIエージェント設計・LLMO・コンテキストエンジニアリングに注力。
          </p>

          <div class="flex flex-wrap justify-center gap-2 mb-6">
            {['LLMO', 'WebRTC', 'Real-time AI', 'Context Engineering', 'MCP', 'Android', 'Claude Code', 'Multi-Agent', 'TypeScript', 'Robotics'].map((tag) => (
              <span class="px-3 py-1 bg-[#1e293b] text-[#60a5fa] text-xs rounded-full border border-[#334155]">
                {tag}
              </span>
            ))}
          </div>

          <div class="flex flex-wrap items-center justify-center gap-3 mb-4">
            <a href="https://kenimoto.dev" target="_blank" rel="noopener noreferrer"
              class="px-5 py-2 bg-[#60a5fa] text-[#0f172a] rounded-lg hover:bg-[#93c5fd] transition-colors font-bold text-sm">
              kenimoto.dev →
            </a>
            <a href="https://www.linkedin.com/in/kenimo49" target="_blank" rel="noopener noreferrer"
              class="px-5 py-2 bg-[#1e293b] text-white rounded-lg hover:bg-[#334155] transition-colors text-sm border border-[#334155]">
              LinkedIn
            </a>
          </div>

          <div class="flex flex-wrap justify-center gap-3">
            {Object.entries(profile.links).filter(([name]) => name !== 'linkedin' && name !== 'portfolio').map(([name, url]) => (
              <a href={url} target="_blank" rel="noopener noreferrer"
                class="text-sm text-[#64748b] hover:text-[#60a5fa] transition-colors">
                {name.charAt(0).toUpperCase() + name.slice(1)}
              </a>
            ))}
          </div>
        </div>
      </section>
    </div>
  </main>
  <Footer />
</Layout>
