---
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const navItems = [
  { label: 'トップ', href: base },
  { label: '事業紹介', href: `${base}products` },
  { label: '会社概要', href: `${base}company` },
  { label: 'お問い合わせ', href: `${base}#contact` },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-navy/95 backdrop-blur-sm">
  <div class="mx-auto max-w-6xl px-4 py-4 flex items-center justify-between">
    <a href={import.meta.env.BASE_URL} class="flex items-center">
      <img src={`${base}images/propel-lab-logo-header.png`} alt="Propel-Lab" class="h-10 w-auto brightness-0 invert" />
    </a>
    <button
      id="menu-toggle"
      class="text-white md:hidden"
      aria-label="メニュー"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
    <nav id="nav-menu" class="hidden md:flex items-center gap-6">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="text-sm text-gray-300 hover:text-white transition-colors"
        >
          {item.label}
        </a>
      ))}
      <a
        href={`${base}en`}
        class="text-xs text-gray-500 hover:text-gray-300 transition-colors ml-2 border border-gray-600 rounded px-2 py-0.5"
      >
        EN
      </a>
    </nav>
  </div>
  <!-- Mobile menu -->
  <nav id="mobile-menu" class="hidden md:hidden bg-navy border-t border-white/10">
    <div class="px-4 py-2 flex flex-col gap-2">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="text-sm text-gray-300 hover:text-white py-2 transition-colors"
        >
          {item.label}
        </a>
      ))}
      <a
        href={`${base}en`}
        class="text-xs text-gray-500 hover:text-gray-300 py-2 transition-colors"
      >
        🌐 English
      </a>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>
