---
import { profile } from '../data/profile';
---

<section id="profile" class="py-20 bg-white">
  <div class="mx-auto max-w-4xl px-4">
    <h2 class="text-3xl font-bold text-center mb-12">代表者プロフィール</h2>
    <div class="bg-gray-50 rounded-xl p-8 md:p-12">
      <div class="mb-6">
        <h3 class="text-2xl font-bold">{profile.name}</h3>
        <p class="text-gray-500">{profile.nameEn} / {profile.title}</p>
        <p class="text-accent font-medium mt-1">{profile.experience}</p>
      </div>
      <div class="mb-6">
        <h4 class="font-semibold mb-2">専門分野</h4>
        <div class="flex flex-wrap gap-2">
          {profile.specialties.map((s) => (
            <span class="px-3 py-1 bg-navy/10 text-navy text-sm rounded-full">{s}</span>
          ))}
        </div>
      </div>
      <div class="mb-6">
        <h4 class="font-semibold mb-2">実績</h4>
        <ul class="space-y-2">
          {profile.highlights.map((h) => (
            <li class="text-gray-600 text-sm flex items-start gap-2">
              <span class="text-accent mt-0.5">&#9654;</span>
              <span>{h}</span>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h4 class="font-semibold mb-2">リンク</h4>
        <div class="flex flex-wrap gap-3">
          {Object.entries(profile.links).map(([name, url]) => (
            <a
              href={url}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-navy hover:text-accent transition-colors underline"
            >
              {name.charAt(0).toUpperCase() + name.slice(1)}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
