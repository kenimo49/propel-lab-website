          "addressLocality": "福岡市中央区",
          "addressRegion": "福岡県",
          "addressCountry": "JP",
          "streetAddress": "天神4丁目6-28 天神ファーストビル7階"
        },
        "foundingDate": "2025-04-24",
        "founder": {
          "@type": "Person",
          "name": "井本 賢"
        },
        "description": "仕組みとエンジニアリングの力で、次世代の経営モデルを構築する"
      },
